{
    "name": "petrocki/iof-xml-php",
    "description": "PHP model classes and XML serialization/deserialization tools for the IOF XML 3.0 data standard",
    "type": "library",
    "keywords": ["iof", "orienteering", "xml", "serializer", "deserializer", "iof-xml"],
    "license": "MIT",
    "autoload": {
        "psr-4": {
            "IofXmlPhp\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "IofXmlPhp\\Tests\\": "tests/"
        }
    },
    "authors": [
        {
            "name": "Adam Petrocki"
        }
    ],
    "require": {
        "php": "^8.3",
        "goetas-webservices/xsd2php-runtime": "^0.2.18",
        "jms/serializer": "^3.32"
    },
    "require-dev": {
        "ext-dom": "*",
        "goetas-webservices/xsd2php": "^0.4.14",
        "friendsofphp/php-cs-fixer": "^3.95",
        "phpunit/phpunit": "^12.5"
    },
    "scripts": {
        "cs-check": "vendor/bin/php-cs-fixer check -vvv",
        "cs-fix": "vendor/bin/php-cs-fixer fix",
        "phpunit": "vendor/bin/phpunit tests/"
    }
}
